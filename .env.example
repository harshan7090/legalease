# ─────────────────────────────────────────────────────────────────────────────
# LegalEase — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your real values below.
# 3. NEVER commit the .env file — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq API Key ──────────────────────────────────────────────────────────────
# Get yours free at: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# ── Model Name ────────────────────────────────────────────────────────────────
# Recommended options (all free on Groq):
#   llama-3.3-70b-versatile      → Fastest, good quality, 8 k context  ← DEFAULT
#   llama3-70b-8192     → Smarter, slightly slower, 8 k context
#   mixtral-8x7b-32768  → Best for long clauses, 32 k context
MODEL_NAME=llama-3.3-70b-versatile

# ── Optional tunables ────────────────────────────────────────────────────────
# Temperature for the main response (0.0 = deterministic, 1.0 = creative)
TEMPERATURE=0.3

# Max tokens to generate for the main response
MAX_TOKENS=1024
